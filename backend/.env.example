# Baza danych (Railway PostgreSQL lub lokalne SQLite)
DATABASE_URL=postgresql://user:password@host:5432/rozliczenia
# Lokalne SQLite (do testów):
# DATABASE_URL=sqlite:///./rozliczenia.db

# Hasło dostępu do aplikacji (HTTP Basic Auth, login: admin)
APP_PASSWORD=zmien_mnie_na_silne_haslo

# Klucz tajny sesji
SECRET_KEY=super-tajny-klucz-zmien-w-produkcji

# CORS — adresy frontendu (oddzielone przecinkami)
CORS_ORIGINS=http://localhost:5173,https://twoja-aplikacja.vercel.app

# Scheduler
INFLACJA_AUTO_REFRESH=true
BACKUP_ENABLED=true
